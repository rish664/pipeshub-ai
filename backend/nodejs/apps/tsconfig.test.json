{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist-test",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "sourceMap": true,
    "types": ["reflect-metadata", "mocha", "node", "sinon"]
  },
  "ts-node": {
    "transpileOnly": true
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
