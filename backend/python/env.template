PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
ALLOWED_ORIGINS=http://localhost:3001

SECRET_KEY=my-secret

QUERY_BACKEND=http://localhost:8000
CONNECTOR_BACKEND=http://localhost:8088
CONNECTOR_PUBLIC_BACKEND=
INDEXING_BACKEND=http://localhost:8091

# Key-Value Store Configuration
# KV_STORE_TYPE: 'redis' or 'etcd' (default: etcd)
KV_STORE_TYPE=etcd

# ETCD Configuration (used when KV_STORE_TYPE=etcd)
ETCD_URL=http://localhost:2379
ETCD_HOST=localhost
ETCD_TIMEOUT=5000

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD:-}@localhost:6379
# marker to identify the different environment for redis db
REDIS_DB=0
REDIS_TIMEOUT=10000
# Redis KV prefix (used when KV_STORE_TYPE=redis)
REDIS_KV_PREFIX=pipeshub:kv:

ARANGO_URL=http://localhost:8529
ARANGO_DB_NAME=es
ARANGO_USERNAME=root
ARANGO_PASSWORD=your_arango_password

KAFKA_BROKERS=localhost:9092

MONGO_URI=mongodb://admin:password@localhost:27017/
MONGO_DB_NAME=enterprise-search

QDRANT_API_KEY=your_qdrant_secret_api_key
QDRANT_HOST=localhost
QDRANT_GRPC_PORT=6334
QDRANT_PORT=6333

OLLAMA_API_URL=http://localhost:11434

OPIK_API_KEY=
OPIK_WORKSPACE=

MAX_TABLE_ROWS_FOR_LLM=1000

# Number of local worker processes for CPU-heavy Docling parsing fallback inside indexing.
# Raise this when the external Docling service is not used and one CPU stays saturated.
LOCAL_DOCLING_PARSE_WORKERS=1

# Number of indexing service processes started by uvicorn.
# Kafka throughput only scales with this if the topic has enough partitions.
INDEXING_UVICORN_WORKERS=1

# Number of Docling service processes started by uvicorn.
DOCLING_UVICORN_WORKERS=1

# Number of worker processes for PDF OCR detection before parser selection.
PDF_OCR_DETECTION_WORKERS=1

# Hard cap for queued indexing tasks held in memory before Kafka reads are paused.
MAX_PENDING_INDEXING_TASKS=40


# Hard cap for how many rows per Excel table are materialized and indexed.
EXCEL_MAX_TABLE_ROWS_TO_INDEX=20000

# Max rows scanned when generating headers for headerless Excel tables.
EXCEL_HEADER_GENERATION_SAMPLE_SCAN_LIMIT=500