# -----------------------------------------------------------------------------
# .env — only the environment selector (no secrets here)
# -----------------------------------------------------------------------------
# Use exactly one. All credentials go in the corresponding file below.
PIPESHUB_TEST_ENV=local
# PIPESHUB_TEST_ENV=prod

# -----------------------------------------------------------------------------
# Credentials live in:
#   .env.local  when PIPESHUB_TEST_ENV=local
#   .env.prod   when PIPESHUB_TEST_ENV=prod
# Do not commit .env.local or .env.prod — they contain secrets.
# See .env.local.example and .env.prod.example for variable names.
# -----------------------------------------------------------------------------
